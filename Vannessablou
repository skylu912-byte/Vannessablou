<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Para ti blo</title>
  <style>
    body {
      background: linear-gradient(135deg, #ff9a9e, #fad0c4);
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }

    .carta {
      background: white;
      padding: 30px;
      border-radius: 20px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
      text-align: center;
      max-width: 350px;

      opacity: 0;
      transform: translateY(20px);
      animation: aparecer 1s ease forwards;
    }

    h1 {
      color: #ff4d6d;
    }

    p {
      font-size: 18px;
      color: #333;
      line-height: 1.5;
    }

    @keyframes aparecer {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>
<body>

  <div class="carta">
    <h1>Para ti blo 💌</h1>
    <p>
      holaaa Vanessa 🫰🏼<br>
      wazaaa bloo 😎✨<br>
      este mensaje es solo para ti no vuelvas con tu ex 🫰🏼
    </p>
  </div>

</body>
</html>
